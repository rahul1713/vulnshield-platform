# VulnShield Platform Environment Configuration

# General
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_SECRET=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vulnshield
POSTGRES_USER=vulnshield
POSTGRES_PASSWORD=vulnshield_secure_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=vulnshield
RABBITMQ_PASSWORD=vulnshield_rabbit_password
RABBITMQ_VHOST=vulnshield

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vulnshield_minio
MINIO_SECRET_KEY=vulnshield_minio_secret
MINIO_BUCKET=vulnshield-evidence
MINIO_USE_SSL=false

# LLM Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Email / Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vulnshield.local
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# LDAP (SSO Ready)
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# MFA
MFA_ENABLED=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# API Gateway
API_GATEWAY_PORT=8080
