# VulnShield Platform Environment Configuration
# Copy to .env for local development. For sandbox, use: ./scripts/generate-sandbox-env.sh

# General
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Secrets — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap admin (auth-service creates on first start when set)
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@vulnshield.local
INIT_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_12_CHARS

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vulnshield
POSTGRES_USER=vulnshield
POSTGRES_PASSWORD=REPLACE_WITH_openssl_rand_hex_24

# Redis (required in sandbox/production)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=vulnshield
RABBITMQ_PASSWORD=REPLACE_WITH_openssl_rand_hex_24
RABBITMQ_VHOST=vulnshield

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=REPLACE_WITH_RANDOM_KEY
MINIO_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_24
MINIO_BUCKET=vulnshield-evidence
MINIO_USE_SSL=false

# LLM — Security AI is LOCAL Ollama + Qwen 3.6 ONLY
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.6
AI_SECURITY_LOCAL_ONLY=true
AI_SECURITY_ALLOWED_MODELS=qwen3.6

# Cloud LLM providers are NOT used for security AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_DEPLOY_ENV=development
NEXT_PUBLIC_ENABLE_DEMO_MODE=false

# Local UI-only dev (never enable in sandbox/production)
# NEXT_PUBLIC_DEMO_USERNAME=admin
# NEXT_PUBLIC_DEMO_PASSWORD=

API_GATEWAY_PORT=8080
