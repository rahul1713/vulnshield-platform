NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Local development only — NEVER enable in sandbox/production
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
NEXT_PUBLIC_DEPLOY_ENV=development

